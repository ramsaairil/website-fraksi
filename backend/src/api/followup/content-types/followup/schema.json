{
  "kind": "collectionType",
  "collectionName": "followups",
  "info": {
    "singularName": "followup",
    "pluralName": "followups",
    "displayName": "Aspiration Follow-up",
    "description": "Follow-up status on citizen aspirations"
  },
  "options": {
    "draftAndPublish": true
  },
  "pluginOptions": {},
  "attributes": {
    "title": {
      "type": "string",
      "required": true
    },
    "description": {
      "type": "text",
      "required": true
    },
    "date": {
      "type": "date"
    },
    "status": {
      "type": "enumeration",
      "enum": [
        "pending",
        "progress",
        "done"
      ],
      "required": true,
      "default": "pending"
    },
    "statusText": {
      "type": "string"
    }
  }
}